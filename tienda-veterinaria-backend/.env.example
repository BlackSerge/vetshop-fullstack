# ============================================================================
# VET-SHOP BACKEND - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copia este archivo a .env y rellena con tus valores reales
# NUNCA comittees .env a git (está en .gitignore)

# ============================================================================
# DATABASE (elige una opción)
# ============================================================================

# OPCIÓN 1: Neon (Cloud - RECOMENDADO para desarrollo)
# Obtén la URL desde: https://console.neon.tech
DATABASE_URL=postgresql://usuario:contraseña@ep-nombrehost.neon.tech/tienda_vet_db?sslmode=require

# OPCIÓN 2: PostgreSQL Local (si prefieres)
# DATABASE_URL_LOCAL=postgresql://postgres:password@localhost:5432/tienda_vet_db

# ============================================================================
# STRIPE PAYMENTS
# ============================================================================
# Obtén las keys desde: https://dashboard.stripe.com/apikeys

# Stripe Secret Key (NUNCA compartir)
STRIPE_SECRET_KEY=sk_test_...

# Stripe Publishable Key (para frontend)
STRIPE_PUBLIC_KEY=pk_test_...

# Stripe Webhook Secret (para webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# CLOUDINARY (Image Storage)
# ============================================================================
# Obtén credenciales desde: https://cloudinary.com/console

CLOUDINARY_CLOUD_NAME=ejemplo
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=aaa_secreto_bbb

# ============================================================================
# DJANGO CONFIGURATION
# ============================================================================

# Secret key (genera una nueva)
DJANGO_SECRET_KEY=django-insecure-unsafe-local-dev-key-change-in-prod

# Debug mode (NUNCA True en producción)
DEBUG=True

# Environment
ENVIRONMENT=development

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Para desarrollo: usar console backend (imprime emails en terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Para producción: usar Gmail, SendGrid, etc
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password

DEFAULT_FROM_EMAIL=noreply@vetshop.com

# ============================================================================
# RENDER DEPLOYMENT (solo si deploys en Render)
# ============================================================================

# RENDER_EXTERNAL_HOSTNAME=your-app-name.onrender.com

# ============================================================================
# FRONTEND URL (para CORS)
# ============================================================================

# Desarrollo local
# FRONTEND_URL=http://localhost:5173

# Producción
# FRONTEND_URL=https://vetshop-fullstack.vercel.app
